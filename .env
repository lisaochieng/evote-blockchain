# MongoDB Connection
MONGODB_URI=mongodb://localhost:27017/voting-app

# Server Configuration
PORT=5000
NODE_ENV=development

# JWT Secret (for authentication tokens)
# This is a random string - in production, use a long random string
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# JWT Token Expiration
JWT_EXPIRE=30d

# Email Configuration (optional - for password reset emails)
# You can configure this later with a service like SendGrid or Gmail
EMAIL_SERVICE=gmail
EMAIL_USERNAME=your-email@gmail.com
EMAIL_PASSWORD=your-app-specific-password
EMAIL_FROM=noreply@votingapp.com

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:8080

# Blockchain Configuration
BLOCKCHAIN_NETWORK=localhost
CONTRACT_ADDRESS=will-be-added-after-deployment